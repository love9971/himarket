# HiMarket Helm 部署配置
# 复制到用户目录并按需修改: cp .env.example ~/himarket-install.env
# install.sh 会自动加载 ~/himarket-install.env

# ========== 部署模式 ==========
# install = 首次安装, upgrade = 升级已有部署（脚本也会自动检测）
DEPLOY_MODE=install

# ========== 基础配置 ==========
NAMESPACE=himarket

# ========== 镜像配置 ==========
HIMARKET_HUB=opensource-registry.cn-hangzhou.cr.aliyuncs.com/higress-group
HIMARKET_IMAGE_TAG=latest
HIMARKET_MYSQL_IMAGE_TAG=latest
NACOS_VERSION=v3.2.1-2026.03.30
NACOS_IMAGE_REGISTRY=nacos-registry.cn-hangzhou.cr.aliyuncs.com
NACOS_IMAGE_REPOSITORY=nacos/nacos-server

# ========== Helm 仓库 ==========
HIGRESS_REPO_NAME=higress.io
HIGRESS_REPO_URL=https://higress.cn/helm-charts
HIGRESS_CHART_REF=higress.io/higress

# ========== 数据库密码 ==========
# 首次安装时由 install.sh 自动生成随机值，升级时沿用已有值
# 如需自定义，取消注释并填写
# MYSQL_ROOT_PASSWORD=
# MYSQL_PASSWORD=

# ========== 服务凭证 ==========
# 首次安装时由 install.sh 自动生成随机值，升级时沿用已有值
# NACOS_USERNAME=nacos
# NACOS_ADMIN_PASSWORD=
# HIGRESS_USERNAME=admin
# HIGRESS_PASSWORD=

# ========== 默认用户 ==========
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
FRONT_USERNAME=user
# FRONT_PASSWORD=

# ========== JVM 调优（可选）==========
# 默认值适合 2-4Gi 内存的容器，按需调整（通过 Helm values.yaml server.javaOpts 覆盖）
# JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=50.0 -XX:MaxMetaspaceSize=512m -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/tmp/heapdump.hprof

# ========== 存储配置 ==========
MYSQL_STORAGE_CLASS=alicloud-disk-essd
MYSQL_STORAGE_SIZE=50Gi
SANDBOX_STORAGE_CLASS=alicloud-disk-essd
SANDBOX_STORAGE_SIZE=50Gi

# ========== Higress IngressClass ==========
HIGRESS_INGRESS_CLASS=himarket

# ========== AI 模型配置（可选）==========
SKIP_AI_MODEL_INIT=true
AI_MODEL_COUNT=0
# 取消下方注释并填写 API Key 即可启用 AI 模型
# SKIP_AI_MODEL_INIT=false
# AI_MODEL_COUNT=1
# AI_MODEL_1_PROVIDER=qwen
# AI_MODEL_1_TYPE=qwen
# AI_MODEL_1_DOMAIN=dashscope.aliyuncs.com
# AI_MODEL_1_PORT=443
# AI_MODEL_1_PROTOCOL=
# AI_MODEL_1_API_KEY=your-api-key-here
# AI_MODEL_1_NAME="Alibaba Cloud Qwen"
# AI_MODEL_1_DEFAULT_MODEL=qwen3.5-plus
